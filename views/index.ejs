<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Global News Wire</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
    <style>

        :root { --bg-dark: #0f0f0f; --bg-panel: #181818; --bg-hover: #2a2a2a; --accent: #00d26a; --text-main: #ffffff; --text-muted: #aaaaaa; --nav-width: 300px; }
        body { margin: 0; background: var(--bg-dark); color: var(--text-main); font-family: 'Inter', sans-serif; display: flex; height: 100vh; overflow: hidden; }
        
        .sidebar { width: var(--nav-width); background: var(--bg-panel); display: flex; flex-direction: column; border-right: 1px solid #333; }
        .brand { padding: 20px; font-weight: 800; font-size: 1.2rem; border-bottom: 1px solid #333; display: flex; align-items: center; gap: 10px; }
        .brand i { color: var(--accent); }
        .channel-list { flex: 1; overflow-y: auto; }
        .category-group { border-bottom: 1px solid #333; }
        .category-header {
            padding: 15px 20px;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--accent);
            font-weight: 800;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--bg-panel);
            transition: background 0.2s, color 0.2s;
        }
        .category-header:hover { background: #222; color: #fff; }
        .category-header .fas { transition: transform 0.3s ease; }
        .category-header.open .fas { transform: rotate(180deg); }
        
        .category-channels {
            display: none;
            background: #111;
            padding: 10px;
        }
        .category-channels.open {
            display: block;
        }
        .channel-card { display: flex; align-items: center; padding: 10px; margin-bottom: 5px; cursor: pointer; border-radius: 6px; transition: 0.2s; }
        .channel-card:hover { background: var(--bg-hover); }
        .channel-card.active { background: rgba(0, 210, 106, 0.1); border-left: 3px solid var(--accent); }
        .ch-logo { width: 40px; height: 40px; background: #000; border-radius: 50%; object-fit: contain; margin-right: 10px; }
        .ch-fallback { width: 40px; height: 40px; background: #333; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; margin-right: 10px; }
        .ch-info { flex: 1; overflow: hidden; }
        .ch-name { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-size: 0.9rem; font-weight: 600; }
        .ch-cat { font-size: 0.75rem; color: var(--text-muted); }       
        .main { flex: 1; display: flex; flex-direction: column; background: #000; }
        .video-container { width: 100%; height: 100%; position: relative; display: flex; align-items: center; justify-content: center; }
        video { width: 100%; height: 100%; max-height: 100vh; outline: none; }
        .error-overlay { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: #ff5555; display: none; text-align: center; }
        .controls { padding: 20px; background: var(--bg-panel); display: flex; justify-content: space-between; align-items: center; }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="brand">
            <i class="fas fa-broadcast-tower"></i> GlobalWire
        </div>   
        <div class="channel-list" id="channelList">
            <% Object.keys(categorizedChannels).forEach(function(category) { %>
                <% if (categorizedChannels[category].length > 0) { %>
                    
                    <% 
                        let hasDefault = false;
                        if (default_channel) {
                            hasDefault = categorizedChannels[category].some(c => c.id === default_channel.id);
                        }
                    %>
                    
                    <div class="category-group">
                        <div class="category-header <%= hasDefault ? 'open' : '' %>" onclick="toggleDropdown(this)">
                            <span><%= category %> (<%= categorizedChannels[category].length %>)</span>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        
                        <div class="category-channels <%= hasDefault ? 'open' : '' %>">
                            <% categorizedChannels[category].forEach(function(channel) { %>
                                <div class="channel-card <%= (default_channel && default_channel.id === channel.id) ? 'active' : '' %>" 
                                     onclick="playStream('<%= channel.id %>', '<%= channel.name %>', this)">
                                    
                                    <% if (channel.logo) { %>
                                        <img src="<%= channel.logo %>" class="ch-logo" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                                        <div class="ch-fallback" style="display:none"><%= channel.name.charAt(0) %></div>
                                    <% } else { %>
                                        <div class="ch-fallback"><%= channel.name.charAt(0) %></div>
                                    <% } %>

                                    <div class="ch-info">
                                        <div class="ch-name"><%= channel.name %></div>
                                        <div class="ch-cat">LIVE SIGNAL</div>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    </div>
                    
                <% } %>
            <% }); %>
        </div>
    </div>

    <div class="main">
        <div class="video-container">
            <video id="video" controls autoplay></video>
            <div class="error-overlay" id="errorMsg">
                <i class="fas fa-exclamation-triangle fa-2x"></i><br>Signal Lost or Geoblocked
            </div>
        </div>
        <div class="controls">
            <h3 id="currentTitle" style="margin:0"><%= default_channel ? default_channel.name : 'No Signal' %></h3>
            <span style="color:var(--accent); font-size:0.9rem;">● LIVE CONNECTION</span>
        </div>
    </div>

    <script>
        function toggleDropdown(headerElement) {
            headerElement.classList.toggle('open');
            const channelsContainer = headerElement.nextElementSibling;
            channelsContainer.classList.toggle('open');
        }

        var video = document.getElementById('video');
        var hls = null;
        var errorOverlay = document.getElementById('errorMsg');

        <% if (default_channel) { %>
            playStream('<%= default_channel.id %>', '<%= default_channel.name %>', document.querySelector('.channel-card.active'));
        <% } %>

        function playStream(url, name, cardElem) {
            document.querySelectorAll('.channel-card').forEach(c => c.classList.remove('active'));
            if(cardElem) cardElem.classList.add('active');
            
            document.getElementById('currentTitle').innerText = name;
            errorOverlay.style.display = 'none';

            if (Hls.isSupported()) {
                if (hls) hls.destroy();
                hls = new Hls();
                hls.loadSource(url);
                hls.attachMedia(video);
                hls.on(Hls.Events.MANIFEST_PARSED, function() {
                    video.play().catch(e => console.log(e));
                });
                hls.on(Hls.Events.ERROR, function (event, data) {
                    if (data.fatal) {
                        errorOverlay.style.display = 'block';
                    }
                });
            } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
                video.src = url;
                video.addEventListener('loadedmetadata', function() {
                    video.play();
                });
            }
        }
    </script>
</body>
</html>

